rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Workers collection: Everyone can read, admin can write
    match /workers/{workerId} {
      allow read: if true;
      allow write: if request.auth != null || true; // For simplicity, adjust if you add auth
    }
    
    // Notes collection: Everyone can read, everyone can write (adjust as needed)
    match /notes/{noteId} {
      allow read, write: if true;
    }
  }
}
